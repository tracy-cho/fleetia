{
  "name": "@fleetia/ui",
  "private": true,
  "main": "dist/index.ts",
  "typings": "dist/index.d.ts",
  "dependencies": {
    "@fleetia/utils": "workspace:^"
  },
  "scripts": {
    "test:generate-output": "jest --json --outputFile=src/.jest-test-results.json",
    "start": "start-storybook -p 6006 -s public",
    "build:storybook": "build-storybook -s public",
    "build:babel": "babel src --source-maps --extensions '.ts,.tsx' --out-dir dist",
    "build:clean": "rm -rf ./dist",
    "build:types": "tsc --emitDeclarationOnly && cp ./custom.d.ts ./dist/",
    "build:sass": "sass src:dist && cp -r ./src/assets/ ./dist/assets/",
    "build:all": "yarn build:clean && yarn build:babel && yarn build:types && yarn build:sass",
    "upload": "aws s3 sync ./storybook-static/ s3://snippet-designsystem/ --acl public-read"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "7.12.13",
    "@babel/plugin-proposal-json-strings": "7.12.13",
    "@babel/plugin-proposal-optional-chaining": "7.12.16",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/plugin-syntax-import-meta": "7.10.4",
    "@babel/plugin-syntax-jsx": "^7.14.5",
    "@babel/preset-react": "^7.16.7",
    "@babel/preset-typescript": "7.12.16",
    "@storybook/addon-actions": "^6.5.10",
    "@storybook/addon-docs": "^6.5.10",
    "@storybook/addon-essentials": "^6.5.10",
    "@storybook/addon-interactions": "^6.5.10",
    "@storybook/addon-links": "^6.5.10",
    "@storybook/addon-storyshots": "^6.5.10",
    "@storybook/builder-webpack5": "^6.5.10",
    "@storybook/manager-webpack5": "^6.5.10",
    "@storybook/node-logger": "^6.5.10",
    "@storybook/preset-create-react-app": "^4.1.2",
    "@storybook/react": "^6.5.10",
    "@storybook/testing-library": "^0.0.13",
    "babel-plugin-transform-rename-import": "^2.3.0",
    "eslint-plugin-storybook": "^0.6.4",
    "storybook-addon-react-router-v6": "^0.1.13"
  }
}
